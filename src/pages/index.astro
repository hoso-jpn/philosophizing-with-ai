---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getPosts } from '../lib/notion';

const posts = await getPosts();

// 1. キーワード（タグ）の集計
const tagCounts = posts.reduce((acc, post) => {
  post.tags.forEach((tag: string) => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

// 出現回数順に並び替え
const sortedTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a);

// 2. シリーズ（カテゴリ）ごとに分類
const series = [
  { name: 'AIと哲学', pattern: /AIと哲学/ },
  { name: 'AIと生物学', pattern: /AIと生物学/ },
  { name: 'AIと統計学', pattern: /AIと統計学/ },
];

const postsBySeries = series.map(s => ({
  name: s.name,
  posts: posts.filter(p => s.pattern.test(p.title))
}));

// 3. 月別アーカイブの作成
const postsByMonth = posts.reduce((acc, post) => {
  const date = new Date(post.date);
  const month = `${date.getFullYear()}年${date.getMonth() + 1}月`;
  if (!acc[month]) acc[month] = [];
  acc[month].push(post);
  return acc;
}, {} as Record<string, any[]>);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={`アーカイブ | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      main { max-width: 720px; margin: auto; padding: 1em; }
      section { margin-bottom: 4rem; }
      h2 { border-bottom: 2px solid #333; padding-bottom: 0.5rem; margin-top: 2rem; display: flex; align-items: center; gap: 0.5rem; }
      
      /* タグクラウドのスタイル */
      .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.5rem; }
      .tag-item { 
        text-decoration: none; 
        background: #f8f9fa; 
        border: 1px solid #e9ecef; 
        padding: 5px 15px; 
        border-radius: 20px; 
        font-size: 0.9rem; 
        color: #0070f3; 
        transition: all 0.2s;
      }
      .tag-item:hover { background: #0070f3; color: white; border-color: #0070f3; }
      .tag-count { font-size: 0.75rem; color: #888; margin-left: 4px; }
      .tag-item:hover .tag-count { color: #eee; }

      .archive-list { list-style: none; padding: 0; }
      .archive-item { margin: 1rem 0; padding-left: 1rem; border-left: 3px solid #eee; }
      .archive-date { font-size: 0.85rem; color: #888; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1 style="font-size: 2.2rem; margin-bottom: 2rem;">思索のアーカイブ</h1>

      <section>
        <h2>キーワード集</h2>
        <p style="font-size: 0.9rem; color: #666;">よく触れられている思索のテーマ</p>
        <div class="tag-cloud">
          {sortedTags.map(([tag, count]) => (
            <a href={`/tags/${tag}`} class="tag-item">
              #{tag} <span class="tag-count">({count})</span>
            </a>
          ))}
        </div>
      </section>

      <section>
        <h2>シリーズ別</h2>
        {postsBySeries.map(s => s.posts.length > 0 && (
          <div style="margin-bottom: 2rem;">
            <h3 style="font-size: 1.2rem; color: #444;">{s.name}</h3>
            <ul class="archive-list">
              {s.posts.map(post => (
                <li class="archive-item">
                  <div class="archive-date">{post.date}</div>
                  <a href={`/posts/${post.id}`} style="font-weight: 500;">{post.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <section>
        <h2>月別</h2>
        {Object.keys(postsByMonth).sort().reverse().map(month => (
          <div style="margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.1rem; color: #666;">{month}</h3>
            <ul class="archive-list">
              {postsByMonth[month].map(post => (
                <li class="archive-item">
                  <a href={`/posts/${post.id}`}>{post.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>