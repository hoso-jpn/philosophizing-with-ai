---
import { getPosts, getPostPage } from '../../lib/notion';
import { marked } from 'marked'; 
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post: any) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { id } = Astro.params;
const { post } = Astro.props;

// 詳細データを取得
const pageData = await getPostPage(id);

// --- 徹底した安全策 ---
// 1. 本文の取得 (pageData?.properties?.Content が無い場合も想定)
const contentRichText = pageData?.properties?.Content?.rich_text || [];
const markdownContent = contentRichText.map((t: any) => t.plain_text).join('') || "本文がありません。";
const htmlContent = marked(markdownContent);

// 2. タイトルの取得 (notion.tsで整形済みの post.title を優先)
const title = post?.title || pageData?.data?.title || "無題";

// 3. タグの取得 (notion.tsで整形済みの post.tags を優先)
const tags = post?.tags || pageData?.data?.tags || [];
---

<html lang="ja">
  <head>
    <BaseHead title={title} description="" />
    <style is:global>
      main { width: 100%; max-width: 720px; margin: 0 auto; padding: 1em; }
      .notion-content { line-height: 1.8; margin-top: 2rem; }
      .tags-container { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
      .tag-badge { background: #eee; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; color: #666; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <h1>{title}</h1>
        
        {tags.length > 0 && (
          <div class="tags-container">
            {tags.map((tag: string) => (
              <span class="tag-badge">#{tag}</span>
            ))}
          </div>
        )}

        <hr />
        <div class="notion-content" set:html={htmlContent}></div>
      </article>
    </main>
    <Footer />
  </body>
</html>